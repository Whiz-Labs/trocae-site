---
const surveyorCode = import.meta.env.PUBLIC_SURVEYOR_CODE || '';
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<meta name="surveyor-code" content={surveyorCode} />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Pesquisa Trocaê - Responda e seja um dos primeiros a testar o app!" />
		<title>Pesquisa Trocaê - Seja um dos primeiros!</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
	</head>
	<body>
		<main>

			<!-- Intro -->
			<div class="intro-screen" id="intro-screen">
				<img src="/logo.png" alt="Trocaê" class="intro-logo" />
				<div class="early-badge">Acesso antecipado</div>
				<h1>Você trocaria algo<br />que não usa mais?</h1>
				<p>Responda rápido e seja um dos <strong>primeiros a testar o Trocaê</strong>!</p>
				<div class="reward-box">
					<div class="reward-item">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
						<span><strong>2 meses grátis</strong> quando o app lançar</span>
					</div>
					<div class="reward-item">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
						<span>Acesso antecipado para testar</span>
					</div>
					<div class="reward-item">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 10-4 4-4-4"/></svg>
						<span>Assinatura com desconto especial</span>
					</div>
				</div>
				<button type="button" class="start-btn" id="start-btn">Começar!</button>
				<p class="intro-time">Leva menos de 30 segundos</p>
			</div>

			<!-- Survey Form -->
			<form id="survey-form" class="survey-form" style="display:none;">
				<a href="/" class="form-logo-link">
					<img src="/logo.png" alt="Trocaê" class="form-logo" />
				</a>
				<div class="progress-bar">
					<div class="progress-fill" id="progress-fill"></div>
				</div>
				<div class="progress-text"><span id="step-current">1</span> de 5</div>

				<!-- Step 1 -->
				<div class="step active" data-step="1">
					<h2>Você tem coisas em casa que não usa mais?</h2>
					<div class="options">
						<label class="option">
							<input type="radio" name="q1" value="Sim, várias coisas" required />
							<span class="option-card">
								<span class="option-emoji">📦</span>
								<span class="option-text">Sim, várias coisas</span>
							</span>
						</label>
						<label class="option">
							<input type="radio" name="q1" value="Algumas" />
							<span class="option-card">
								<span class="option-emoji">📋</span>
								<span class="option-text">Algumas</span>
							</span>
						</label>
						<label class="option">
							<input type="radio" name="q1" value="Não muito" />
							<span class="option-card">
								<span class="option-emoji">🤷</span>
								<span class="option-text">Não muito</span>
							</span>
						</label>
					</div>
				</div>

				<!-- Step 2 -->
				<div class="step" data-step="2">
					<button type="button" class="back-btn" onclick="goToStep(1)">← Voltar</button>
					<h2>O que você mais trocaria?</h2>
					<div class="q2-status" id="q2-status">
						<span class="q2-counter" id="q2-counter">0/2</span>
						<span class="q2-message" id="q2-message">Toque para escolher até 2 opções</span>
					</div>
					<div class="options">
						<label class="option">
							<input type="checkbox" name="q2" value="Roupas" />
							<span class="option-card">
								<span class="option-emoji">👕</span>
								<span class="option-text">Roupas <span class="option-hint">(camisetas, calças, vestidos…)</span></span>
							</span>
						</label>
						<label class="option">
							<input type="checkbox" name="q2" value="Brinquedos" />
							<span class="option-card">
								<span class="option-emoji">🧸</span>
								<span class="option-text">Brinquedos <span class="option-hint">(jogos, bonecas, carrinhos…)</span></span>
							</span>
						</label>
						<label class="option">
							<input type="checkbox" name="q2" value="Eletrônicos" />
							<span class="option-card">
								<span class="option-emoji">📱</span>
								<span class="option-text">Eletrônicos <span class="option-hint">(celular, fone, tablet…)</span></span>
							</span>
						</label>
						<label class="option">
							<input type="checkbox" name="q2" value="Livros" />
							<span class="option-card">
								<span class="option-emoji">📚</span>
								<span class="option-text">Livros <span class="option-hint">(romance, didático, HQ…)</span></span>
							</span>
						</label>
						<label class="option">
							<input type="checkbox" name="q2" value="Acessórios" />
							<span class="option-card">
								<span class="option-emoji">👜</span>
								<span class="option-text">Acessórios <span class="option-hint">(bolsas, relógios, bijuterias, perfumes…)</span></span>
							</span>
						</label>
						<label class="option">
							<input type="checkbox" name="q2" value="Móveis / Decoração" />
							<span class="option-card">
								<span class="option-emoji">🪑</span>
								<span class="option-text">Móveis / Decoração <span class="option-hint">(cadeira, quadro, luminária…)</span></span>
							</span>
						</label>
					</div>
				</div>

				<!-- Step 3 -->
				<div class="step" data-step="3">
					<button type="button" class="back-btn" onclick="goToStep(2)">← Voltar</button>
					<h2>O que te motivaria mais a trocar?</h2>
					<div class="options">
						<label class="option">
							<input type="radio" name="q3" value="Economizar dinheiro" required />
							<span class="option-card">
								<span class="option-emoji">💰</span>
								<span class="option-text">Economizar dinheiro</span>
							</span>
						</label>
						<label class="option">
							<input type="radio" name="q3" value="Ajudar o meio ambiente" />
							<span class="option-card">
								<span class="option-emoji">🌱</span>
								<span class="option-text">Ajudar o meio ambiente</span>
							</span>
						</label>
						<label class="option">
							<input type="radio" name="q3" value="Conhecer pessoas" />
							<span class="option-card">
								<span class="option-emoji">🤝</span>
								<span class="option-text">Conhecer pessoas</span>
							</span>
						</label>
						<label class="option">
							<input type="radio" name="q3" value="Desapegar de coisas" />
							<span class="option-card">
								<span class="option-emoji">📦</span>
								<span class="option-text">Desapegar de coisas</span>
							</span>
						</label>
					</div>
				</div>

				<!-- Step 4 -->
				<div class="step" data-step="4">
					<button type="button" class="back-btn" onclick="goToStep(3)">← Voltar</button>
					<h2>Você usaria um aplicativo para trocar coisas com pessoas da sua cidade?</h2>
					<div class="options">
						<label class="option">
							<input type="radio" name="q4" value="Sim" required />
							<span class="option-card">
								<span class="option-emoji">🙌</span>
								<span class="option-text">Sim!</span>
							</span>
						</label>
						<label class="option">
							<input type="radio" name="q4" value="Talvez" />
							<span class="option-card">
								<span class="option-emoji">🤔</span>
								<span class="option-text">Talvez</span>
							</span>
						</label>
						<label class="option">
							<input type="radio" name="q4" value="Não" />
							<span class="option-card">
								<span class="option-emoji">😐</span>
								<span class="option-text">Não</span>
							</span>
						</label>
					</div>
				</div>

				<!-- Step 5: Contato -->
				<div class="step" data-step="5">
					<button type="button" class="back-btn" onclick="goToStep(4)">← Voltar</button>
					<h2>Quase lá! Como quer receber novidades?</h2>
					<p class="step-sub">Vamos te avisar quando o app estiver pronto. Você ganhará <strong>2 meses grátis</strong> + desconto especial!</p>

					<div class="contact-toggle">
						<button type="button" class="toggle-btn active" id="toggle-whatsapp" data-mode="whatsapp">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
							WhatsApp
						</button>
						<button type="button" class="toggle-btn" id="toggle-email" data-mode="email">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
							E-mail
						</button>
					</div>

					<div class="form-group" id="whatsapp-group">
						<input
							type="tel"
							id="whatsapp"
							name="whatsapp"
							placeholder="(83) 99999-9999"
							maxlength="15"
						/>
					</div>
					<div class="form-group" id="email-group" style="display:none;">
						<input
							type="email"
							id="email"
							name="email"
							placeholder="seu@email.com"
						/>
					</div>

					<div class="consent-area">
						<label class="consent-checkbox">
							<input type="checkbox" id="consent-check" checked />
							<span>Aceito receber novidades sobre o lançamento do Trocaê</span>
						</label>
						<p class="consent-warning" id="consent-warning">
							Sem isso, você pode perder o lançamento e seus benefícios!
						</p>
					</div>

					<button type="submit" class="submit-btn" id="submit-btn">
						<span class="btn-text">Garantir meu acesso!</span>
						<span class="btn-loading" style="display:none;">Enviando...</span>
					</button>
				</div>
			</form>

			<!-- Success -->
			<div id="survey-success" class="success-screen" style="display:none;">
				<img src="/logo.png" alt="Trocaê" class="success-logo" />
				<h2>Você está dentro!</h2>
				<p class="success-guaranteed">Você já garantiu:</p>
				<div class="success-rewards">
					<div class="success-reward">2 meses grátis</div>
					<div class="success-reward">Acesso antecipado</div>
					<div class="success-reward">Desconto especial</div>
				</div>
				<div class="social-proof">
					<span class="fire">🔥</span>
					<span>Mais de <strong id="signup-count">…</strong> pessoas já entraram na lista</span>
				</div>
				<div class="success-actions">
					<a href="https://instagram.com/trocaeoficial" target="_blank" rel="noopener noreferrer" class="vip-btn">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
						Seguir @trocaeoficial
					</a>
					<p class="instagram-hint">Vamos postar os resultados da pesquisa por lá!</p>
					<a href="/" class="home-link">Voltar ao site</a>
				</div>
			</div>
		</main>
	</body>
</html>

<script>
	const steps = document.querySelectorAll('.step') as NodeListOf<HTMLElement>;
	const progressFill = document.getElementById('progress-fill')!;
	const stepCurrent = document.getElementById('step-current')!;
	const totalSteps = steps.length;
	let currentStep = 1;
	const codigo = new URLSearchParams(window.location.search).get('ref')
		|| document.querySelector('meta[name="surveyor-code"]')?.getAttribute('content')
		|| '';

	function updateProgress() {
		const pct = (currentStep / totalSteps) * 100;
		progressFill.style.width = `${pct}%`;
		stepCurrent.textContent = String(currentStep);
	}

	(window as any).goToStep = goToStep;

	const introScreen = document.getElementById('intro-screen')!;
	const surveyForm = document.getElementById('survey-form') as HTMLFormElement;

	document.getElementById('start-btn')!.addEventListener('click', () => {
		introScreen.style.display = 'none';
		surveyForm.style.display = 'block';
	});

	const consentCheck = document.getElementById('consent-check') as HTMLInputElement;
	const consentWarning = document.getElementById('consent-warning')!;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

	consentCheck.addEventListener('change', () => {
		consentWarning.classList.toggle('visible', !consentCheck.checked);
	});

	function goToStep(n: number) {
		const goingBack = n < currentStep;
		steps.forEach(s => s.classList.remove('active', 'exit', 'exit-right'));

		const prev = document.querySelector(`.step[data-step="${currentStep}"]`) as HTMLElement;
		if (prev) prev.classList.add(goingBack ? 'exit-right' : 'exit');

		currentStep = n;
		updateProgress();

		setTimeout(() => {
			steps.forEach(s => s.classList.remove('active', 'exit', 'exit-right'));
			const next = document.querySelector(`.step[data-step="${n}"]`) as HTMLElement;
			if (next) {
				next.style.animation = goingBack ? 'fadeInLeft 0.3s ease' : 'fadeIn 0.3s ease';
				next.classList.add('active');
			}
		}, 250);
	}

	document.querySelectorAll('.step[data-step="1"] input, .step[data-step="3"] input, .step[data-step="4"] input').forEach(input => {
		input.addEventListener('change', () => {
			const step = parseInt((input as HTMLElement).closest('.step')!.getAttribute('data-step')!);
			setTimeout(() => goToStep(step + 1), 400);
		});
	});

	const q2Checkboxes = document.querySelectorAll('input[name="q2"]') as NodeListOf<HTMLInputElement>;
	const q2Counter = document.getElementById('q2-counter')!;
	const q2Message = document.getElementById('q2-message')!;
	const q2Status = document.getElementById('q2-status')!;

	function updateQ2Status() {
		const count = document.querySelectorAll('input[name="q2"]:checked').length;
		q2Counter.textContent = `${count}/2`;

		if (count === 0) {
			q2Message.textContent = 'Escolha 2 opções';
			q2Status.className = 'q2-status';
		} else if (count === 1) {
			q2Message.textContent = 'Escolha mais 1!';
			q2Status.className = 'q2-status q2-can-add';
		} else {
			q2Message.textContent = 'Pronto!';
			q2Status.className = 'q2-status q2-done';
		}
	}

	q2Checkboxes.forEach(cb => {
		cb.addEventListener('change', () => {
			const checked = document.querySelectorAll('input[name="q2"]:checked');
			if (checked.length > 2) {
				cb.checked = false;
				return;
			}
			updateQ2Status();
			if (checked.length === 2) {
				setTimeout(() => goToStep(3), 500);
			}
		});
	});

	updateProgress();

	// Contact toggle
	let contactMode = 'whatsapp';
	const toggleWhatsapp = document.getElementById('toggle-whatsapp')!;
	const toggleEmail = document.getElementById('toggle-email')!;
	const whatsappGroup = document.getElementById('whatsapp-group')!;
	const emailGroup = document.getElementById('email-group')!;

	function setContactMode(mode: string) {
		contactMode = mode;
		toggleWhatsapp.classList.toggle('active', mode === 'whatsapp');
		toggleEmail.classList.toggle('active', mode === 'email');
		whatsappGroup.style.display = mode === 'whatsapp' ? 'block' : 'none';
		emailGroup.style.display = mode === 'email' ? 'block' : 'none';
	}

	toggleWhatsapp.addEventListener('click', () => setContactMode('whatsapp'));
	toggleEmail.addEventListener('click', () => setContactMode('email'));

	// WhatsApp mask
	const whatsappInput = document.getElementById('whatsapp') as HTMLInputElement;
	whatsappInput.addEventListener('input', (e) => {
		let v = (e.target as HTMLInputElement).value.replace(/\D/g, '');
		if (v.length > 11) v = v.slice(0, 11);
		if (v.length > 7) {
			v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
		} else if (v.length > 2) {
			v = `(${v.slice(0,2)}) ${v.slice(2)}`;
		} else if (v.length > 0) {
			v = `(${v}`;
		}
		(e.target as HTMLInputElement).value = v;
	});

	const emailInput = document.getElementById('email') as HTMLInputElement;
	const form = document.getElementById('survey-form') as HTMLFormElement;
	const btnText = submitBtn.querySelector('.btn-text') as HTMLElement;
	const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLElement;

	form.addEventListener('submit', async (e) => {
		e.preventDefault();

		let digits = '';
		let email = '';

		if (contactMode === 'whatsapp') {
			digits = whatsappInput.value.replace(/\D/g, '');
			if (digits.length < 10) {
				whatsappInput.setCustomValidity('Informe um número válido com DDD');
				whatsappInput.reportValidity();
				return;
			}
			whatsappInput.setCustomValidity('');
		} else {
			email = emailInput.value.trim();
			if (!email || !email.includes('@')) {
				emailInput.setCustomValidity('Informe um e-mail válido');
				emailInput.reportValidity();
				return;
			}
			emailInput.setCustomValidity('');
		}

		const q1 = (document.querySelector('input[name="q1"]:checked') as HTMLInputElement)?.value || '';
		const q2Checked = document.querySelectorAll('input[name="q2"]:checked') as NodeListOf<HTMLInputElement>;
		const q2 = Array.from(q2Checked).map(c => c.value).join(', ');
		const q3 = (document.querySelector('input[name="q3"]:checked') as HTMLInputElement)?.value || '';
		const q4 = (document.querySelector('input[name="q4"]:checked') as HTMLInputElement)?.value || '';

		submitBtn.disabled = true;
		btnText.style.display = 'none';
		btnLoading.style.display = 'inline';

		try {
			await fetch(
				'https://script.google.com/macros/s/AKfycbyVvMshDvpTQdq56cfCnGy6Q7yb8tI__dCSOUGM1lGwAzvIeMDz0YRTtZNHmMoQutcI/exec',
				{
					method: 'POST',
					mode: 'no-cors',
					headers: { 'Content-Type': 'text/plain' },
					body: JSON.stringify({
						tipo: 'pesquisa',
						whatsapp: digits,
						email,
						q1,
						q2,
						q3,
						q4,
						codigo,
						consent: consentCheck.checked ? 'sim' : 'não',
					}),
				}
			);

			surveyForm.style.display = 'none';
			(document.getElementById('survey-success') as HTMLElement).style.display = 'block';

			try {
				const res = await fetch('https://script.google.com/macros/s/AKfycbzagXzGDZSFDwa5gGWbOPj8JsbIws95XOa7hXB89MLpLIEsv3UmPPBwhwwdpXMhti8/exec');
				const { count } = await res.json();
				document.getElementById('signup-count')!.textContent = String(count + 20);
			} catch {
				document.querySelector('.social-proof')!.remove();
			}
		} catch {
			submitBtn.disabled = false;
			btnText.style.display = 'inline';
			btnLoading.style.display = 'none';
		}
	});
</script>

<style>
	:root {
		--teal: #1a8a8a;
		--teal-dark: #147272;
		--teal-light: #e0f4f4;
