<style>
	:root {
		--teal: #1a8a8a;
		--teal-dark: #147272;
		--teal-light: #e0f4f4;
		--orange: #f5a623;
		--orange-dark: #e0941a;
		--orange-light: #fef3e0;
		--cream: #faf6f1;
		--cream-dark: #f0e8dd;
		--text-dark: #2c3e50;
		--text-muted: #6b7c8a;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Nunito', sans-serif;
		color: var(--text-dark);
		background: var(--cream);
		overflow-x: hidden;
	}

	/* Nav */
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 2rem;
		background: rgba(250, 246, 241, 0.9);
		backdrop-filter: blur(10px);
		z-index: 100;
		border-bottom: 1px solid rgba(0,0,0,0.05);
	}

	.nav-logo {
		width: 36px;
		height: 36px;
	}

	.nav-brand {
		font-size: 1.4rem;
		font-weight: 800;
		color: var(--teal);
	}

	/* Hero */
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 6rem 2rem 4rem;
		overflow: hidden;
	}

	.hero-content {
		position: relative;
		z-index: 2;
	}

	.hero-logo {
		width: 100px;
		height: 100px;
		margin-bottom: 1.5rem;
		animation: float 3s ease-in-out infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-10px); }
	}

	.hero h1 {
		font-size: 2.8rem;
		font-weight: 800;
		line-height: 1.2;
		margin-bottom: 1rem;
		color: var(--text-dark);
	}

	.hero h1 .highlight {
		color: var(--teal);
		font-weight: 700;
	}

	.hero h1 strong {
		color: var(--text-dark);
		font-weight: 900;
	}

	.hero-sub {
		font-size: 1.2rem;
		color: var(--text-muted);
		margin-bottom: 2rem;
	}

	.cta-button {
		display: inline-block;
		background: var(--teal);
		color: white;
		padding: 1rem 2.5rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: 700;
		font-size: 1.1rem;
		transition: all 0.3s ease;
		box-shadow: 0 4px 15px rgba(26, 138, 138, 0.3);
	}

	.cta-button:hover {
		background: var(--teal-dark);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(26, 138, 138, 0.4);
	}

	/* Blobs */
	.hero-blob {
		position: absolute;
		border-radius: 50%;
		opacity: 0.15;
	}

	.blob-teal {
		width: 400px;
		height: 400px;
		background: var(--teal);
		bottom: -100px;
		left: -100px;
		border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
	}

	.blob-orange {
		width: 300px;
		height: 300px;
		background: var(--orange);
		top: 80px;
		right: -80px;
		border-radius: 40% 60% 70% 30% / 40% 70% 30% 60%;
	}

	/* Sections */
	.section {
		padding: 5rem 2rem;
		max-width: 1100px;
		margin: 0 auto;
	}

	.section h2 {
		font-size: 2.2rem;
		font-weight: 800;
		text-align: center;
		margin-bottom: 0.5rem;
		color: var(--text-dark);
	}

	.section-sub {
		text-align: center;
		color: var(--text-muted);
		font-size: 1.1rem;
		margin-bottom: 3rem;
	}

	/* Steps */
	.steps-section {
		background: white;
		border-radius: 24px;
		margin-top: -2rem;
		padding: 4rem 2rem;
		box-shadow: 0 4px 30px rgba(0,0,0,0.06);
	}

	.steps-section h2 {
		margin-bottom: 3rem;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.step {
		text-align: center;
		padding: 2rem 1.5rem;
		border-radius: 16px;
		transition: transform 0.3s ease;
		position: relative;
	}

	.step:hover {
		transform: translateY(-5px);
	}

	.step-number {
		position: absolute;
		top: 0.5rem;
		left: 50%;
		transform: translateX(-50%);
		width: 28px;
		height: 28px;
		background: var(--orange);
		color: white;
		border-radius: 50%;
		font-weight: 800;
		font-size: 0.85rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.step-icon {
		width: 90px;
		height: 90px;
		margin: 1rem auto;
		background: var(--teal-light);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--teal);
	}

	.step h3 {
		font-size: 1.2rem;
		font-weight: 700;
		margin: 1rem 0 0.5rem;
		color: var(--teal-dark);
	}

	.step p {
		color: var(--text-muted);
		font-size: 0.95rem;
	}

	/* Categories */
	.categories-section {
		padding-top: 4rem;
	}

	.categories-section h2 {
		margin-bottom: 0.5rem;
	}

	.categories {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.category-card {
		background: white;
		border-radius: 16px;
		padding: 2rem 1rem;
		text-align: center;
		transition: all 0.3s ease;
		box-shadow: 0 2px 15px rgba(0,0,0,0.05);
		cursor: default;
	}

	.category-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 8px 25px rgba(0,0,0,0.1);
	}

	.category-icon {
		width: 80px;
		height: 80px;
		margin: 0 auto 1rem;
		background: var(--cream);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--teal);
	}

	.category-card span {
		font-weight: 700;
		font-size: 1.05rem;
		color: var(--text-dark);
	}

	/* CTA Section */
	.cta-section {
		text-align: center;
		position: relative;
	}

	.cta-content {
		background: white;
		border-radius: 24px;
		padding: 4rem 2rem;
		box-shadow: 0 4px 30px rgba(0,0,0,0.06);
		position: relative;
		overflow: hidden;
	}

	.cta-content::before {
		content: '';
		position: absolute;
		width: 250px;
		height: 250px;
		background: var(--teal);
		opacity: 0.08;
		border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
		bottom: -80px;
		left: -60px;
	}

	.cta-content::after {
		content: '';
		position: absolute;
		width: 200px;
		height: 200px;
		background: var(--orange);
		opacity: 0.08;
		border-radius: 40% 60% 70% 30% / 40% 70% 30% 60%;
		top: -60px;
		right: -40px;
	}

	.cta-logo {
		width: 70px;
		height: 70px;
		margin-bottom: 1.5rem;
	}

	.cta-content h2 {
		font-size: 2.5rem;
		font-weight: 800;
		line-height: 1.2;
		margin-bottom: 1rem;
		color: var(--text-dark);
	}

	.cta-content p {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin-bottom: 2rem;
	}

	.launch-badge {
		display: inline-block;
		background: var(--teal);
		color: white;
		padding: 0.8rem 2rem;
		border-radius: 50px;
		font-weight: 700;
		font-size: 1rem;
		margin-bottom: 2rem;
		position: relative;
		z-index: 1;
	}

	.social-links {
		position: relative;
		z-index: 1;
	}

	.instagram-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-dark);
		text-decoration: none;
		font-weight: 600;
		font-size: 1.05rem;
		padding: 0.7rem 1.5rem;
		border-radius: 12px;
		background: var(--cream);
		transition: all 0.3s ease;
	}

	.instagram-link:hover {
		background: var(--cream-dark);
		transform: translateY(-2px);
	}

	/* Footer */
	footer {
		background: var(--teal-dark);
		color: white;
		padding: 2rem;
		text-align: center;
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
	}

	.footer-logo {
		width: 40px;
		height: 40px;
		filter: brightness(0) invert(1);
	}

	.footer-brand {
		font-size: 1.3rem;
		font-weight: 800;
	}

	footer p {
		font-size: 0.85rem;
		opacity: 0.7;
		margin-top: 0.5rem;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero h1 {
			font-size: 2rem;
		}

		.steps {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.categories {
			grid-template-columns: repeat(2, 1fr);
		}

		.cta-content h2 {
			font-size: 2rem;
		}

		nav {
			padding: 0.8rem 1.2rem;
		}
	}

	@media (max-width: 480px) {
		.hero h1 {
			font-size: 1.7rem;
		}

		.section h2 {
			font-size: 1.7rem;
		}

		.categories {
			grid-template-columns: 1fr 1fr;
			gap: 1rem;
		}
	}
</style>
